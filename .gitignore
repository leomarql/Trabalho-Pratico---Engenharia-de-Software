# ==========================================
# FRONTEND (Node.js + React)
# ==========================================
# Dependências
node_modules/

# Arquivos de build/produção
build/
dist/

# Logs de erro de gerenciadores de pacote
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# BACKEND (Python + FastAPI)
# ==========================================
# Arquivos compilados do Python
__pycache__/
*.py[cod]
*$py.class

# Ambientes Virtuais (MUITO IMPORTANTE)
venv/
env/
.venv/
env.bak/

# Banco de dados local (caso uso de SQLite no desenvolvimento)
*.sqlite3
*.db

# ==========================================
# SEGURANÇA E VARIÁVEIS DE AMBIENTE
# ==========================================
# NUNCA suba chaves de API, senhas ou configs locais
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==========================================
# IDEs E SISTEMA OPERACIONAL
# ==========================================
# Configurações de editores de código
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Arquivos de Sistema Operacional
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.db